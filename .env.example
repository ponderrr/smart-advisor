# ============================================
# SMART ADVISOR — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# --- FRONTEND (required) ---
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# The following are Supabase Edge Function secrets.
# Set these in Supabase Dashboard → Edge Functions → Manage secrets.
# Do NOT add these to Vercel — they never touch the frontend.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TMDB_API_KEY=your_tmdb_api_key_here

# --- LOCAL DEV ONLY (optional) ---
# Set to "true" to bypass the per-IP rate limit on /api/demo-recommendations.
# Leave unset everywhere except your local machine. NEVER set in Vercel.
# DISABLE_RATE_LIMIT=true

# --- ERROR TRACKING (optional) ---
# If you wire up Sentry later, drop the DSN here. The app does not import
# @sentry/nextjs today — uncomment and install when you're ready.
# NEXT_PUBLIC_SENTRY_DSN=
