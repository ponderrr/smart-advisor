# ============================================
# SMART ADVISOR — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# --- FRONTEND (required) ---
# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- EDGE FUNCTIONS (set in Supabase dashboard → Settings → Edge Functions) ---
# Anthropic API key — required for question and recommendation generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TMDB API key — optional, enables real movie posters and metadata
# Get at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Google Books API key — optional, enables real book covers and metadata
# Get at: https://console.developers.google.com/
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# --- NOTES ---
# SUPABASE_URL and SUPABASE_ANON_KEY are auto-injected into edge functions
# by the Supabase runtime. You do not need to set them manually for functions.
# TMDB and Google Books keys are optional — the app falls back to
# placeholder images and default metadata if they are absent.
