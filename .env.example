# ============================================
# SMART ADVISOR — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# --- FRONTEND (required) ---
# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# The following are Supabase Edge Function secrets.
# Set these in Supabase Dashboard → Edge Functions → Manage secrets.
# Do NOT add these to Vercel — they never touch the frontend.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TMDB_API_KEY=your_tmdb_api_key_here
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here
